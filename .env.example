# Example environment configuration for crypto-signals-system.
#
# Copy to `.env` and fill in real values for local development:
#     cp .env.example .env
#
# `.env` is gitignored; this `.env.example` IS committed as documentation of
# every variable the app reads. Keep the two in sync: when you add a field to
# src/config/settings.py, add it here too (with no value).
#
# In production the Lambda resolves these at startup from SSM Parameter Store
# (API keys) / Secrets Manager (the DB credential) into the same env vars -- the
# code path is identical, only the source differs.

# --- Secrets (required) ---
# Anthropic API key for Claude Sonnet 4.5 (Step 1.6 LLM wrapper).
ANTHROPIC_API_KEY=
# Telegram bot token from @BotFather (Step 1.10 notifier).
TELEGRAM_BOT_TOKEN=
# Postgres DSN. Local docker-compose default:
#   postgresql://signals:signals@localhost:5432/signals
DATABASE_URL=

# --- Required (non-secret) ---
# Target Telegram chat id (numeric) or '@channel' handle.
TELEGRAM_CHAT_ID=

# --- Macro provider keys (optional; Skeptic, Step 2.5) ---
# Leave blank to disable macro context; the Skeptic then degrades to NoMacroData
# (FR-4.3) and the Judge downgrades confidence to medium.
# FRED (DXY proxy / US10Y / Fed Funds). Free key: fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# Twelve Data (S&P 500 / volatility via SPY / VIXY free-tier ETF proxies).
TWELVE_DATA_API_KEY=

# --- Operational (optional; defaults shown) ---
# Comma-separated watchlist. Defaults to the SPEC Slice 1-2 watchlist.
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
# Root logging level: DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO
